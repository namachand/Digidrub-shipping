# CAEX SOAP API credentials
CAEX_URL=http://wsqa.caexlogistics.com:1880/wsCAEXLogisticsSB/wsCAEXLogisticsSB.asmx
CAEX_LOGIN=SEARS
CAEX_PASSWORD=d7956b01c68cf6172ea141b8627c58d4
CAEX_CREDITO=5000764

# Origin poblado — where Ashley ships FROM
# Default: 2343 (Aldea Chitol). Change this once you have Guatemala City's code.
CAEX_ORIGEN_POBLADO=2343

# Default piece code for most shipments.
# 2 = PAQUETES (generic package). Change if CAEX suggests PRODUCTO A/B/C for furniture.
CAEX_DEFAULT_PIEZA=2

# Default delivery type. 1 = door-to-door.
CAEX_DEFAULT_ENTREGA=1

# Backup flat rate in GTQ if CAEX fails for all services.
# Ops team manually reviews flagged orders and reaches out if rate is wrong.
BACKUP_RATE_GTQ=75

# Server port (Render sets this automatically; local default 3000)
PORT=3000

# Cache TTL in seconds (default 30 min)
CACHE_TTL_SECONDS=1800

# Log level: debug | info | warn | error
LOG_LEVEL=info
